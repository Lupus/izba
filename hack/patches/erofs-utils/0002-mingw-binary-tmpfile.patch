 int erofs_tmpfile(void)
 {
+#ifdef __MINGW32__
+	/* mingw-w64's mkstemp opens in CRT TEXT mode (no _O_BINARY): LF
+	 * bytes get CRLF-expanded on write and 0x1a reads back as EOF,
+	 * silently corrupting any binary payload staged in the disk buffer.
+	 * unlink() on an open file also never works on Windows.  Open
+	 * explicitly binary with delete-on-close, in the native temp dir.
+	 */
+	char buf[PATH_MAX];
+	const char *dirs[] = { getenv("TMPDIR"), getenv("TMP"),
+			       getenv("TEMP"), "." };
+	unsigned int i, j;
+	int fd;
+
+	for (i = 0; i < sizeof(dirs) / sizeof(dirs[0]); i++) {
+		if (!dirs[i])
+			continue;
+		for (j = 0; j < 64; j++) {
+			(void)snprintf(buf, sizeof(buf), "%s/erofs.%u.%u.tmp",
+				       dirs[i], (unsigned int)_getpid(), j);
+			fd = _open(buf, _O_RDWR | _O_CREAT | _O_EXCL |
+				   _O_BINARY | _O_TEMPORARY,
+				   _S_IREAD | _S_IWRITE);
+			if (fd >= 0)
+				return fd;
+			if (errno != EEXIST)
+				break;
+		}
+	}
+	return -errno;
+#else
 #define	TRAILER		"tmp.XXXXXXXXXX"
 	char buf[PATH_MAX];
 	int fd;
