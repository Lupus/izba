# TCP forwarding is intentionally left at the OpenSSH default (enabled): VS Code
# Remote-SSH port-forwarding requires it. The guest is NIC-less — forwards can
# only reach guest loopback + the izbad policy-gated egress gateway, so this
# does not widen the guest's reach.
X11Forwarding no

ListenAddress 127.0.0.1:22
HostKey /run/izba/ssh/ssh_host_ed25519_key
AuthorizedKeysFile /run/izba/ssh/authorized_keys
PidFile /run/izba/ssh/sshd.pid
PermitRootLogin prohibit-password
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
# Session entry: root's login shell is `/init` (izba-init itself), which acts as
# a restricted login shell that enters the running `izba` crun container via
# `crun exec` (Stance B), sharing the container's mount/pid namespaces. There is
# no ForceCommand and no ChrootDirectory. OpenSSH invokes /init as:
#   interactive login  (`ssh host`):      argv[0] = "-init" (dash-prefixed)
#   remote command     (`ssh host <cmd>`): /init -c "<cmd>"
# izba-init detects both forms and routes them into crun exec.
# sftp/scp: scp-over-ssh and VS Code Remote-SSH arrive as a remote command
# ($SSH_ORIGINAL_COMMAND via the -c form) and work correctly; native in-container
# sftp-server is a follow-up.
Subsystem sftp internal-sftp
PrintMotd no
AcceptEnv LANG LC_*
