# TCP forwarding is intentionally left at the OpenSSH default (enabled): VS Code
# Remote-SSH port-forwarding requires it. The guest is NIC-less — forwards can
# only reach guest loopback + the izbad policy-gated egress gateway, so this
# does not widen the guest's reach.
X11Forwarding no

ListenAddress 127.0.0.1:22
HostKey /run/izba/ssh/ssh_host_ed25519_key
AuthorizedKeysFile /run/izba/ssh/authorized_keys
PidFile /run/izba/ssh/sshd.pid
PermitRootLogin prohibit-password
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes
# Session entry: instead of ChrootDirectory, every SSH session (interactive
# shell, remote command, scp/sftp) is routed through the `__ssh-session`
# ForceCommand. It enters the running `izba` crun container via `crun exec`
# (Stance B), sharing the container's mount/pid namespaces — so the shell sees
# the container's /proc, /dev/pts, /tmp, etc., exactly like `izba exec`.
ForceCommand /init __ssh-session
# NOTE: ForceCommand overrides subsystem requests too, so sftp/scp also run
# the crun-exec wrapper. Native in-container sftp-server support is a follow-up.
Subsystem sftp internal-sftp
PrintMotd no
AcceptEnv LANG LC_*
