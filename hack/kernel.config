# Kernel config FRAGMENT for izba microVMs.
# Merged over x86_64_defconfig by build-kernel.sh via merge_config.sh.
# All options are =y (no modules). defconfig already enables most parent
# symbols; this fragment pins the subset that izba specifically requires.

# PVH boot entry point. Cloud Hypervisor loads `vmlinux` via the x86/HVM
# direct boot ABI (PVH), which requires the kernel ELF to carry the
# XEN_ELFNOTE_PHYS32_ENTRY note emitted by arch/x86/platform/pvh/head.S. That
# object is built only when CONFIG_PVH=y. Without it, CH refuses the kernel
# with `VmBoot(KernelMissingPvhHeader)` before any console output. x86_64
# defconfig leaves PVH off and nothing selects it here (no Xen), so pin it.
# `config PVH` is a plain bool with no extra dependencies.
CONFIG_PVH=y

# VirtIO bus + devices. No virtio-net: the guest is a NIC-less vsock island
# (see the networking + disabled-NIC sections below).
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_CONSOLE=y

# vsock (guest↔host control channel)
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y

# Filesystems
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_EROFS_FS=y
CONFIG_EXT4_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y

# Device filesystem (needed by init before /dev is populated)
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Networking core. The guest is a NIC-less vsock island: no VMM driver attaches
# a NIC (CH/OpenVMM pass no --net) and init brings up only lo + dummy0
# (net.rs). Keep the socket families the egress datapath actually uses — AF_UNIX
# and AF_INET (the workload's outbound TCP + the stub's loopback DNS/TCP-REDIRECT
# sockets; AF_VSOCK is pinned above). No AF_PACKET (nothing uses raw sockets) and
# no IP_PNP/DHCP (there is no `ip=` cmdline arg — kernel IP autoconfig is dead).
CONFIG_NET=y
CONFIG_UNIX=y
CONFIG_INET=y

# Network devices: dummy0 (the structural-deny carrier for the static guest IP)
# lives directly under NETDEVICES, NOT the ETHERNET vendor-driver menu — so keep
# these two and drop ETHERNET (see the disabled-NIC section below).
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y

# PCI bus (virtio-pci transport)
CONFIG_PCI=y
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# Serial console (ttyS0 boot output)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# ELF + script execution
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# Core pseudo-filesystems
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# Namespaces / isolation primitives
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_MULTIUSER=y
# User namespaces are load-bearing: the in-guest workload container ALWAYS runs
# in a `user` namespace (crun OCI runtime, Option A uid mapping) so the image
# USER owns the host-owned virtiofs /workspace while image-root files keep
# mapping to container-root (setuid `sudo` works). x86_64_defconfig does NOT
# enable CONFIG_USER_NS (it is not listed there and the symbol defaults off), so
# WITHOUT this pin the guest boots with `CONFIG_USER_NS=n` — `unshare(CLONE_NEWUSER)`
# then EINVALs and every sandbox fails closed (observed on the pre-pin kernel).
# See izba-init oci.rs (`userns_floor_met`) and runtime_config.rs
# (`transpose_identity_map`).
CONFIG_USER_NS=y

# POSIX / IPC primitives required by most userland
CONFIG_POSIX_TIMERS=y
CONFIG_EPOLL=y
CONFIG_FUTEX=y
CONFIG_SHMEM=y

# Pseudo-terminal support (CONFIG_UNIX98_PTYS enables devpts)
CONFIG_UNIX98_PTYS=y

# Hardware RNG (entropy source in the guest)
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Hyper-V guest stack — required for OpenVMM --hv mode.
# Without --hv, OpenVMM routes virtio-vsock through legacy PCI (VirtioBus::Auto
# → VirtioBus::Pci), which fails with "missing PCI INT#A line" because the
# direct-boot chipset has no ISA-PCI interrupt routing.  With --hv, the device
# is presented via Hyper-V VPCI (VMBus), which requires hv_vmbus + hv_pci in
# the guest.  HYPERVISOR_GUEST and PCI_MSI are already enabled by x86_64
# defconfig; these two symbols are the only additions needed.
# NOTE: this delta must be re-validated against the CH integration suite before
# being declared production-ready — enabling PARAVIRT-adjacent options can
# affect Cloud Hypervisor boot paths that don't use --hv.
CONFIG_HYPERV=y
CONFIG_PCI_HYPERV=y
# (HYPERV_NET / hv_netvsc was here for OpenVMM --net consomme; that NIC datapath
# was deleted in M1 — all egress is vsock now — so hv_netvsc is gone too, see
# the disabled-NIC section below.)

# Egress stub (M1): the guest stub intercepts outbound TCP via an nftables
# `nat` table REDIRECT rule, then recovers the original destination via
# getsockopt(SOL_IP, SO_ORIGINAL_DST) — which the conntrack NAT machinery
# tracks.  NF_TABLES_IPV4 needs NF_TABLES; NFT_REDIR needs NFT_NAT which needs
# NF_NAT (and NF_CONNTRACK underneath).  SO_ORIGINAL_DST itself rides on
# NF_CONNTRACK + NF_NAT — no dedicated symbol on 6.12.  dummy0 is the NIC-less
# end-state carrier for the static guest IP (M1 phase C).
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REDIR=y
CONFIG_DUMMY=y

# ---------------------------------------------------------------------------
# Disabled host-hardware subsystems (NIC-less microVM has no datapath for them)
# ---------------------------------------------------------------------------
# The parent x86_64_defconfig is a desktop/laptop config: it compiles in real
# physical-hardware drivers that can never bind inside izba's guest, which sees
# only a fixed virtual device set (virtio-blk/-vsock/-fs/-rng/-console, 8250
# serial, PCI, ACPI; no NIC). Beyond bloating vmlinux, several of these probe
# physical-CPU MSRs / ACPI tables the hypervisor (CH/WHP/OpenVMM) does not
# emulate, spraying "unchecked MSR access error" call traces across the boot
# console captured to logs/console.log — e.g. intel_pstate reading
# RDMSR 0x1AD (MSR_TURBO_RATIO_LIMIT) and writing WRMSR 0x199 (IA32_PERF_CTL).
# The host owns power/thermal/frequency; the guest has no display, audio, USB,
# radio, or non-virtio storage. Turn the lot off.
#
# These are top-level menu symbols (not force-`select`ed), so
# merge_config.sh + `make olddefconfig` reliably disable them and their
# children. A symbol that some still-enabled driver `select`s would be kept on
# rather than break the build, so this list is fail-safe, never fail-broken.

# NIC stack: the guest has no network interface. Egress is fully vsock-based
# (guest dials izbad on vsock 1027; passt/consomme/ip=dhcp were deleted in M1),
# and the only interfaces init brings up are lo + dummy0. So no virtio-net, no
# hv_netvsc, and none of the dozens of physical NIC vendor drivers ETHERNET
# gates. IP_PNP/DHCP (kernel IP autoconfig) and AF_PACKET are likewise unused.
# CONFIG_VIRTIO_NET is not set
# CONFIG_HYPERV_NET is not set
# CONFIG_ETHERNET is not set
# CONFIG_PACKET is not set
# CONFIG_IP_PNP is not set
# CONFIG_IP_PNP_DHCP is not set

# CPU frequency scaling is host-owned and meaningless in a guest. The actual
# trigger for the boot-time "unchecked MSR access error" splat is
# SCHED_MC_PRIO (Intel Turbo Boost Max 3.0 / ITMT core-priority scheduling,
# default y), which force-`select`s X86_INTEL_PSTATE + CPU_FREQ. Disabling it
# is what removes intel_pstate's RDMSR 0x1AD (MSR_TURBO_RATIO_LIMIT) / WRMSR
# 0x199 (IA32_PERF_CTL) probes; with its only selector gone, the CPU_FREQ menu
# then honours the disables below. (A plain `# CONFIG_CPU_FREQ is not set`
# alone is silently re-enabled by SCHED_MC_PRIO's select — verified.)
# CONFIG_SCHED_MC_PRIO is not set
# CONFIG_CPU_FREQ is not set
# CONFIG_X86_INTEL_PSTATE is not set
# CONFIG_X86_ACPI_CPUFREQ is not set
# CONFIG_X86_AMD_PSTATE is not set

# (Thermal + hwmon are force-`select`ed by ACPI_PROCESSOR, so they can't be
# turned off from this fragment without also dropping ACPI processor C-state
# idle — a separate, boot-path-affecting call. With no sensor drivers bound
# they stay quiet in a VM, so they're deliberately left enabled here.)

# Laptop/desktop power plumbing: no battery or AC adapter in a microVM.
# CONFIG_ACPI_BATTERY is not set
# CONFIG_ACPI_AC is not set

# No display device — serial console only (console=ttyS0). Drops i915, AGP,
# and (unused) virtio-gpu.
# CONFIG_DRM is not set
# CONFIG_AGP is not set

# No audio device.
# CONFIG_SOUND is not set

# No USB controller is exposed to the guest.
# CONFIG_USB_SUPPORT is not set

# No radios.
# CONFIG_WLAN is not set
# CONFIG_WIRELESS is not set

# Storage is virtio-blk only (vda/vdb/vd…): no ATA/SATA, SCSI, or MD/device-
# mapper stack (the `device-mapper: ioctl` boot line comes from CONFIG_MD/_DM).
# CONFIG_ATA is not set
# CONFIG_SCSI is not set
# CONFIG_MD is not set

# Misc physical buses with no microVM presence.
# CONFIG_PCMCIA is not set
# CONFIG_WATCHDOG is not set
